# Copy this file to .env and adjust values
# Generate secrets with: ./scripts/generate-secrets.sh

# Domain (required)
FORGEJO_DOMAIN=git.yourdomain.com

# Authentik middleware (empty to disable protection)
# TRAEFIK_MIDDLEWARES=authentik@docker

# OpenID via Authentik (optional)
# FORGEJO_OPENID_SIGNIN=true
# FORGEJO_OPENID_SIGNUP=false
