# .env.local - Local overrides (not in git)
# This file overrides values in .env during install.sh
# Copy to .env.local and adjust values

# Domain (required)
FORGEJO_DOMAIN=git.yourdomain.com

# Authentik middleware (empty to disable protection)
TRAEFIK_MIDDLEWARES=authentik@docker

# Traefik network name
TRAEFIK_NETWORK=traefik-proxy

# OpenID via Authentik (optional)
FORGEJO_OPENID_SIGNIN=false
FORGEJO_OPENID_SIGNUP=false
